# Portfolio subdomain (ADR-0006): enk.tickerbeats.com (frontend) + enk-api.tickerbeats.com (backend).
# When implementation begins, see iac-tickerbeats/docs/portfolio-architecture.md for the full env stanza.
# EndorseKit — environment template.
#
# Copy this file to .env (gitignored) for local dev. Real prod secrets
# live in Google Secret Manager (Cloud Run runtime injection).
#
# EndorseKit is two deployables: a SvelteKit web app (`web/`) and a Go
# backend service (`backend/`) — see docs/product-research.md §2 and
# docs/adr/0001-go-backend-for-endorsements-and-jobs.md. Local-dev workflow:
#
#   1. Run `supabase start` from repo root. First time downloads ~3 GB of
#      Docker images; subsequent starts take ~30s. The command prints the
#      local API URL, anon key, service_role key, and DB URL — paste them
#      into the SUPABASE_* vars below.
#   2. `make db.migrate` applies migrations.
#   3. `make backend.dev` boots the Go service on :8080 (air live-reload).
#   4. `make web.dev` boots the SvelteKit dev server on :5173.

###############################################################################
# Runtime
###############################################################################
NODE_ENV=development                           # development | staging | production
PORT=5173                                       # SvelteKit dev port (adapter-node listens on $PORT in prod)
BACKEND_PORT=8080                               # Go service port (Cloud Run injects $PORT)
PUBLIC_SITE_URL=http://localhost:5173           # used by email/PWA/booking-page/endorsement-PDF absolute URLs
PUBLIC_API_BASE_URL=http://localhost:8080       # SvelteKit → Go backend base URL
LOG_LEVEL=info                                  # debug | info | warn | error

###############################################################################
# Supabase (data + auth — single vendor)
# https://supabase.com/dashboard → Project → Settings → API + Database
#
# Local dev values come from `supabase start`. Production values come
# from the hosted Supabase project (F-03).
###############################################################################
# Public client config — safe to expose to the browser
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=eyJ.local-anon-key.eyJ

# Server-only secrets — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJ.local-service-role-key.eyJ
# Direct Postgres connection used by golang-migrate AND the Go backend's
# pgxpool. The Supabase CLI prints this on `supabase start`.
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# JWT verification — the Go backend validates Supabase-issued ES256 JWTs
# against the JWKS endpoint. Audience is 'authenticated' for GoTrue.
SUPABASE_JWT_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated

###############################################################################
# Google OAuth (configured AS A PROVIDER inside Supabase Auth)
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client IDs
# Add these in Supabase Dashboard → Authentication → Providers → Google.
###############################################################################
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxx

###############################################################################
# Stripe — Checkout + Customer Portal (the CFI's own subscription)
# AND Stripe Connect (the CFI invoices students; payouts to the CFI).
# https://dashboard.stripe.com/apikeys
# Price IDs come from https://dashboard.stripe.com/products after F-07.
###############################################################################
STRIPE_SECRET_KEY=sk_test_xxx
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx                 # platform-account webhook signing secret
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_connect_xxx # connected-account events webhook signing secret
STRIPE_PRICE_MONTHLY=price_xxx                  # $12/mo recurring (the CFI's subscription)
STRIPE_PRICE_ANNUAL=price_xxx                   # $120/yr recurring (the CFI's subscription)
# Stripe Connect — Standard accounts; the platform onboards each CFI.
STRIPE_CONNECT_CLIENT_ID=ca_xxx                 # Connect OAuth / onboarding client ID

###############################################################################
# Resend (transactional + booking/lesson reminder email + endorsement PDFs)
# https://resend.com/api-keys
# SPF + DKIM + DMARC on the sender domain are F-06 prerequisites.
###############################################################################
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@endorsekit.app
RESEND_REPLY_TO=hello@endorsekit.app
RESEND_WEBHOOK_SECRET=whsec_resend_xxx          # verifies Resend deliverability webhooks

###############################################################################
# Cloudflare R2 (object storage — server-generated endorsement PDFs,
# invoice PDFs, and the immutable registry export archive)
# https://dash.cloudflare.com → R2 → Manage R2 API tokens
###############################################################################
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET=endorsekit-files
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_PUBLIC_HOSTNAME=https://files.endorsekit.app

###############################################################################
# Google Cloud (Cloud Run hosting; us-central1 single region)
# Two services: endorsekit-web (SvelteKit) and endorsekit-api (Go).
###############################################################################
GCP_PROJECT_ID=endorsekit-prod
CLOUD_RUN_REGION=us-central1
CLOUD_RUN_WEB_SERVICE=endorsekit-web
CLOUD_RUN_API_SERVICE=endorsekit-api
# Path to a service-account JSON for local dev. CI uses Workload Identity
# Federation — no JSON key file needed there.
GOOGLE_APPLICATION_CREDENTIALS=/Users/sander/.gcp/endorsekit-local-dev-sa.json

###############################################################################
# Cloud Scheduler → daily booking/lesson reminder cron
# The scheduler posts an OIDC-authed request to the Go backend's /cron/daily.
# CRON_OIDC_AUDIENCE must match the Cloud Run service URL.
###############################################################################
CRON_OIDC_AUDIENCE=https://endorsekit-api-xxx.us-central1.run.app
CRON_OIDC_SERVICE_ACCOUNT=endorsekit-cron@endorsekit-prod.iam.gserviceaccount.com

###############################################################################
# Sentry (errors — client + server SDKs, web + Go backend)
# https://sentry.io/settings/<org>/projects/
###############################################################################
PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN_BACKEND=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=development
SENTRY_ORG=endorsekit
SENTRY_PROJECT=endorsekit-web
SENTRY_AUTH_TOKEN=sntrys_xxx

###############################################################################
# PostHog Cloud (analytics + session replay + feature flags)
# https://posthog.com → Project → Project API Key
###############################################################################
PUBLIC_POSTHOG_KEY=phc_xxx
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

###############################################################################
# Signed URLs / tokens (HMAC-SHA256 for public booking-page links,
# endorsement-PDF download links, and the public booking confirmation page)
# Generate with:  openssl rand -base64 32
###############################################################################
URL_SIGNING_SECRET=replace-with-32-byte-random-base64

# Endorsement-record integrity — HMAC key used to seal each issued
# endorsement row into the append-only registry (a per-record content
# hash chained to the prior record). Rotating it does NOT invalidate
# sealed records (the algorithm + key version are stored per row), but
# see docs/operating-playbook.md for the rotation procedure.
ENDORSEMENT_SEAL_SECRET=replace-with-32-byte-random-base64

###############################################################################
# GitHub (for local `gh` CLI / MCP — already configured globally on your box)
###############################################################################
# GH_TOKEN is read by `gh`; use `gh auth login` instead of pasting here.
# GH_TOKEN=ghp_xxx
